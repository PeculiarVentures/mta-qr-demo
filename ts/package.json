{
  "name": "mta-qr-demo",
  "version": "0.1.0",
  "description": "Reference implementation of MTA-QR: Merkle Tree Assertions for Verifiable QR Codes",
  "scripts": {
    "test": "cd sdk && npm test && cd ..",
    "test:vectors": "npx tsx sdk/src/test/vectors.test.ts",
    "issuer": "npx tsx issuer/main.ts",
    "verifier": "npx tsx verifier/main.ts",
    "test:signing": "npx tsx sdk/src/test/signing.test.ts",
    "test:all": "cd sdk && npm test && cd .. && npx tsc --noEmit",
    "typecheck": "npx tsc --noEmit"
  },
  "keywords": [
    "mta-qr",
    "merkle-tree",
    "transparency-log",
    "qr-code",
    "pki",
    "post-quantum"
  ],
  "author": "Ryan Hurst / Peculiar Ventures",
  "license": "Apache-2.0",
  "dependencies": {
    "@noble/post-quantum": "^0.5.4",
    "cborg": "^4.5.8",
    "qrcode": "^1.5.4"
  },
  "type": "module",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/qrcode": "^1.5.6",
    "typescript": "^5.9.3",
    "tsx": "^4.21.0"
  }
}